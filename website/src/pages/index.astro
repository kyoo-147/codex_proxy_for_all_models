---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Codex Proxy for All Models">
  <div class="relative min-h-[100dvh] overflow-hidden selection:bg-white/20">
    <!-- Background glow orbs -->
    <div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
      <div class="absolute top-[-20%] left-[-10%] w-[60%] h-[60%] rounded-full bg-blue-500/10 blur-[128px]"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] rounded-full bg-emerald-500/8 blur-[128px]"></div>
      <div class="absolute top-[40%] right-[20%] w-[30%] h-[30%] rounded-full bg-violet-500/6 blur-[128px]"></div>
    </div>

    <!-- NAV: Floating island (detached, glass pill) -->
    <header class="relative z-50 flex justify-center pt-6">
      <div class="w-max backdrop-blur-2xl bg-white/5 border border-white/10 rounded-full px-5 py-2.5 flex items-center gap-8 shadow-2xl">
        <div class="flex items-center gap-2 text-sm font-medium text-white/80">
          <!-- Custom proxy icon: ultra-thin geometric -->
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60">
            <path d="M12 2v6M12 16v6M4 12h6M14 12h6"/>
            <circle cx="12" cy="12" r="2" fill="currentColor" fill-opacity="0.3"/>
          </svg>
          Codex Proxy
        </div>
        <nav class="flex items-center gap-6 text-sm font-medium text-white/50">
          <a href="#providers" class="hover:text-white/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">Providers</a>
          <a href="#pool-mode" class="hover:text-white/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">Pool Mode</a>
          <a href="#quick-start" class="hover:text-white/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)]">Quick Start</a>
          <a href="https://github.com/kyoo-147/codex_proxy_for_all_models" target="_blank" rel="noopener" class="flex items-center gap-2 px-4 py-1.5 rounded-full bg-white text-black text-sm font-medium hover:bg-white/90 transition-all duration-300 ease-[cubic-bezier(0.32,0.72,0,1)] active:scale-[0.98]">
            GitHub
            <!-- Nested icon arrow -->
            <span class="w-5 h-5 rounded-full bg-black/10 flex items-center justify-center group-hover:translate-x-[1px] group-hover:-translate-y-[1px] transition-transform duration-300">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        </nav>
      </div>
    </header>

    <!-- HERO -->
    <section class="relative z-10 pt-32 pb-24 px-6 max-w-7xl mx-auto">
      <div class="flex flex-col items-center text-center max-w-3xl mx-auto mb-24 reveal">
        <div class="inline-flex items-center gap-1.5 px-4 py-1 rounded-full bg-white/5 border border-white/10 text-[11px] uppercase tracking-[0.2em] font-medium text-white/40 mb-8">
          v0.3 &mdash; MIT Licensed &mdash; Pure Python
        </div>
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-white leading-[1.05]">
          One IDE.<br/>
          <span class="text-white/40">Any&nbsp;Model.</span>
        </h1>
        <p class="text-lg text-white/50 max-w-xl mt-6 leading-relaxed">
          The lightweight bridge between Codex and any OpenAI-compatible backend.
          Zero dependencies. Pure Python. Instant setup.
        </p>
        <div class="flex gap-4 pt-8">
          <a href="#quick-start" class="group relative flex items-center gap-3 px-8 py-3.5 rounded-full bg-white text-black text-sm font-medium hover:bg-white/90 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] active:scale-[0.98] shadow-2xl">
            Get Started
            <span class="w-7 h-7 rounded-full bg-black/10 flex items-center justify-center group-hover:translate-x-[2px] group-hover:-translate-y-[1px] transition-transform duration-300">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
          <a href="https://github.com/kyoo-147/codex_proxy_for_all_models" target="_blank" rel="noopener" class="group flex items-center gap-3 px-8 py-3.5 rounded-full border border-white/15 text-white/70 text-sm font-medium hover:bg-white/5 hover:text-white/90 transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] active:scale-[0.98]">
            View Source
            <span class="w-7 h-7 rounded-full bg-white/10 flex items-center justify-center group-hover:translate-x-[2px] group-hover:-translate-y-[1px] transition-transform duration-300">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        </div>
      </div>

      <!-- HERO: Asymmetrical Bento -->
      <div class="reveal reveal-delay-1">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 auto-rows-auto md:auto-rows-[120px]">
          <!-- Left side stat cards (stacked) -->
          <div class="order-2 md:order-1 md:col-span-3 space-y-4">
            <div class="backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.25rem] p-5 shadow-lg">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)]">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/60"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                </div>
                <div>
                  <p class="text-[11px] uppercase tracking-[0.15em] font-medium text-white/30">Latency</p>
                  <p class="text-sm font-medium text-white/80">Near-zero overhead</p>
                </div>
              </div>
            </div>
            <div class="backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.25rem] p-5 shadow-lg">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)]">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/60"><path d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="text-[11px] uppercase tracking-[0.15em] font-medium text-white/30">Responses API</p>
                  <p class="text-sm font-medium text-white/80">Native Translation</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Terminal (centerpiece, largest) -->
          <div class="order-1 md:order-2 col-span-1 md:col-span-6 md:row-span-3 bg-black rounded-[1.75rem] p-1.5 shadow-2xl ring-1 ring-white/[0.06] relative overflow-hidden flex flex-col">
            <div class="h-10 border-b border-white/[0.06] flex items-center px-4 gap-2">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500/60"></div>
              <p class="text-xs text-white/20 font-mono ml-4">codex-proxy</p>
            </div>
            <div class="p-5 md:p-7 font-mono text-xs md:text-sm leading-relaxed text-white/40">
              <p><span class="text-emerald-400/80">➜</span> <span class="text-blue-400/60">~</span> export CODEX_PROXY_UPSTREAM_BASE_URL="http://127.0.0.1:11434/v1"</p>
              <p><span class="text-emerald-400/80">➜</span> <span class="text-blue-400/60">~</span> export CODEX_PROXY_UPSTREAM_MODEL="qwen2.5-coder:7b"</p>
              <p><span class="text-emerald-400/80">➜</span> <span class="text-blue-400/60">~</span> python -m codex_proxy_for_all_models</p>
              <p class="text-white/25 mt-3">INFO: Starting Codex Proxy...</p>
              <p class="text-white/25">INFO: Mode: single_upstream</p>
              <p class="text-white/25">INFO: Listening on http://127.0.0.1:8787</p>
              <p class="text-white/25 mt-4">INFO: 127.0.0.1 — "GET /health HTTP/1.1" 200 OK</p>
              <p class="text-white/25">INFO: 127.0.0.1 — "POST /responses HTTP/1.1" 200 OK</p>
            </div>
          </div>

          <!-- Right side stat cards (stacked) -->
          <div class="order-3 md:order-3 md:col-span-3 space-y-4">
            <div class="backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.25rem] p-5 shadow-lg">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)]">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/60"><rect x="4" y="4" width="16" height="16" rx="2"/><path d="M9 9h.01M15 9h.01M9 15h6"/></svg>
                </div>
                <div>
                  <p class="text-[11px] uppercase tracking-[0.15em] font-medium text-white/30">Deploy</p>
                  <p class="text-sm font-medium text-white/80">Anywhere</p>
                </div>
              </div>
            </div>
            <div class="backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.25rem] p-5 shadow-lg">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center shrink-0 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)]">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/60"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </div>
                <div>
                  <p class="text-[11px] uppercase tracking-[0.15em] font-medium text-white/30">Ecosystem</p>
                  <p class="text-sm font-medium text-white/80">Vendor-neutral</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Bottom cards: Local & Remote + Pool Mode -->
          <div class="order-4 md:col-span-3 backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.25rem] p-5 shadow-lg">
            <h3 class="text-sm font-semibold text-white/80 mb-2">Local &amp; Remote</h3>
            <p class="text-xs text-white/40 mb-4">Run Ollama locally or tap cloud APIs. No lock-in.</p>
            <div class="grid grid-cols-2 gap-2">
              <div class="bg-white/5 border border-white/[0.06] rounded-xl px-3 py-2 text-center text-xs font-medium text-white/50">vLLM</div>
              <div class="bg-white/5 border border-white/[0.06] rounded-xl px-3 py-2 text-center text-xs font-medium text-white/50">SGLang</div>
              <div class="bg-white/5 border border-white/[0.06] rounded-xl px-3 py-2 text-center text-xs font-medium text-white/50">LM Studio</div>
              <div class="bg-white/5 border border-white/[0.06] rounded-xl px-3 py-2 text-center text-xs font-medium text-white/50">Ollama</div>
            </div>
          </div>
          <div class="order-5 md:col-span-3 backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.25rem] p-5 shadow-lg">
            <h3 class="text-sm font-semibold text-white/80 mb-2">Pool Mode</h3>
            <p class="text-xs text-white/40 mb-4">Auto-failover across your model pool.</p>
            <div class="space-y-2">
              <div class="flex items-center justify-between text-xs px-3 py-2 bg-white/5 rounded-xl border border-white/[0.06]">
                <span class="font-mono text-white/50">codex-fast</span>
                <span class="w-2 h-2 rounded-full bg-emerald-400/80"></span>
              </div>
              <div class="flex items-center justify-between text-xs px-3 py-2 bg-white/5 rounded-xl border border-white/[0.06]">
                <span class="font-mono text-white/50">codex-balanced</span>
                <span class="w-2 h-2 rounded-full bg-emerald-400/80"></span>
              </div>
              <div class="flex items-center justify-between text-xs px-3 py-2 bg-white/5 rounded-xl border border-white/[0.06]">
                <span class="font-mono text-white/50">codex-strong</span>
                <span class="w-2 h-2 rounded-full bg-emerald-400/80"></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Architecture Value Strip -->
    <section class="relative z-10 py-28 border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-10 reveal">
        <div class="text-center">
          <p class="text-[11px] uppercase tracking-[0.2em] font-medium text-white/20 mb-4">Philosophy</p>
          <h3 class="text-lg font-semibold text-white/90 mb-3">Lightweight by design</h3>
          <p class="text-sm text-white/40 leading-relaxed max-w-xs mx-auto">
            Zero runtime dependencies. Pure Python standard library &mdash; no FastAPI, no Flask, no Node, no database.
          </p>
        </div>
        <div class="text-center">
          <p class="text-[11px] uppercase tracking-[0.2em] font-medium text-white/20 mb-4">Integration</p>
          <h3 class="text-lg font-semibold text-white/90 mb-3">Codex-first</h3>
          <p class="text-sm text-white/40 leading-relaxed max-w-xs mx-auto">
            Translates Responses API to chat/completions transparently. Codex sees your backend as a first-class model.
          </p>
        </div>
        <div class="text-center">
          <p class="text-[11px] uppercase tracking-[0.2em] font-medium text-white/20 mb-4">Flexibility</p>
          <h3 class="text-lg font-semibold text-white/90 mb-3">Vendor-neutral</h3>
          <p class="text-sm text-white/40 leading-relaxed max-w-xs mx-auto">
            Switch from Ollama to NVIDIA to OpenRouter by changing one env var. No config changes, no redeploys.
          </p>
        </div>
      </div>
    </section>

    <!-- Providers Section -->
    <section id="providers" class="relative z-10 py-28 border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="max-w-2xl mb-16 reveal">
          <p class="text-[11px] uppercase tracking-[0.2em] font-medium text-white/20 mb-4">Ecosystem</p>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white leading-[1.05]">Supported Providers</h2>
          <p class="text-lg text-white/40 mt-4 max-w-lg">
            Any OpenAI-compatible <code class="text-white/60 bg-white/5 px-2 py-0.5 rounded font-mono text-sm">chat/completions</code> endpoint works. Swap upstreams freely.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 reveal reveal-delay-1">
          <!-- Double-bezel card: Local -->
          <div class="backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.75rem] p-1.5 shadow-lg hover:bg-white/[0.05] transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group">
            <div class="bg-black rounded-[calc(1.75rem-0.375rem)] p-7 shadow-[inset_0_1px_1px_rgba(255,255,255,0.06)]">
              <div class="w-11 h-11 rounded-2xl bg-white/5 border border-white/[0.06] flex items-center justify-center mb-7 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)]">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/50"><rect x="2" y="2" width="20" height="20" rx="4"/><path d="M16 8l-4 4 4 4"/><path d="M8 8l4 4-4 4"/></svg>
              </div>
              <h3 class="text-lg font-semibold text-white/90 mb-2">Local Servers</h3>
              <p class="text-sm text-white/40 leading-relaxed">Ollama, LM Studio, vLLM, SGLang — run models entirely on your machine.</p>
            </div>
          </div>
          <!-- Double-bezel card: NVIDIA -->
          <div class="backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.75rem] p-1.5 shadow-lg hover:bg-white/[0.05] transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group">
            <div class="bg-black rounded-[calc(1.75rem-0.375rem)] p-7 shadow-[inset_0_1px_1px_rgba(255,255,255,0.06)]">
              <div class="w-11 h-11 rounded-2xl bg-white/5 border border-white/[0.06] flex items-center justify-center mb-7 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)]">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/50"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              </div>
              <h3 class="text-lg font-semibold text-white/90 mb-2">NVIDIA Build</h3>
              <p class="text-sm text-white/40 leading-relaxed">Blazing endpoints like <code class="text-white/60">z-ai/glm-5.2</code> via <code class="text-white/60">integrate.api.nvidia.com</code>.</p>
            </div>
          </div>
          <!-- Double-bezel card: Cloud -->
          <div class="backdrop-blur-2xl bg-white/[0.03] border border-white/[0.06] rounded-[1.75rem] p-1.5 shadow-lg hover:bg-white/[0.05] transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group">
            <div class="bg-black rounded-[calc(1.75rem-0.375rem)] p-7 shadow-[inset_0_1px_1px_rgba(255,255,255,0.06)]">
              <div class="w-11 h-11 rounded-2xl bg-white/5 border border-white/[0.06] flex items-center justify-center mb-7 shadow-[inset_0_1px_1px_rgba(255,255,255,0.08)]">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-white/50"><circle cx="12" cy="12" r="10"/><path d="M22 12H2"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
              </div>
              <h3 class="text-lg font-semibold text-white/90 mb-2">Cloud &amp; Hosted</h3>
              <p class="text-sm text-white/40 leading-relaxed">DeepSeek, OpenRouter, or any <code class="text-white/60">chat/completions</code> cloud provider.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pool Mode Section (Editorial Split) -->
    <section id="pool-mode" class="relative z-10 py-28 border-t border-white/[0.06]">
      <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-20 items-center reveal">
        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] font-medium text-white/20 mb-6 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-blue-400/60"></span> New in v0.2+
          </p>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight text-white leading-[1.05] mb-6">Enterprise-grade Pool Mode</h2>
          <p class="text-lg text-white/40 leading-relaxed mb-10">
            Automatic failover, multi-key rotation, and request cooldown. Codex sees three curated models. The proxy handles the complexity.
          </p>
          <ul class="space-y-5">
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-emerald-400/80"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div>
                <span class="font-medium text-white/80 block text-sm">Automatic Failover</span>
                <span class="text-sm text-white/40">Falls back to the next model if the primary is down or rate-limited.</span>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-emerald-400/80"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div>
                <span class="font-medium text-white/80 block text-sm">Multi-key Rotation</span>
                <span class="text-sm text-white/40">Distributes load across API keys to stay within rate limits.</span>
              </div>
            </li>
            <li class="flex items-start gap-4">
              <div class="w-6 h-6 rounded-full bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center shrink-0 mt-0.5">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-emerald-400/80"><path d="M20 6L9 17l-5-5"/></svg>
              </div>
              <div>
                <span class="font-medium text-white/80 block text-sm">Curated Codex Profiles</span>
                <span class="text-sm text-white/40">Maps any backend to <code class="text-white/60 bg-white/5 px-1.5 py-0.5 rounded font-mono">codex-fast</code>, <code class="text-white/60 bg-white/5 px-1.5 py-0.5 rounded font-mono">codex-balanced</code>, or <code class="text-white/60 bg-white/5 px-1.5 py-0.5 rounded font-mono">codex-strong</code>.</span>
              </div>
            </li>
          </ul>
        </div>
        <!-- Code block right -->
        <div class="bg-black border border-white/[0.06] rounded-[1.75rem] p-1.5 shadow-2xl">
          <div class="bg-[#050505] rounded-[calc(1.75rem-0.375rem)] p-6 shadow-[inset_0_1px_1px_rgba(255,255,255,0.06)]">
            <div class="flex items-center justify-between mb-5">
              <span class="text-xs font-mono text-white/20">pool-config.toml</span>
            </div>
            <pre class="font-mono text-sm leading-relaxed text-white/40 overflow-x-auto"><code><span class="text-white/15"># Configure logical profiles</span>
mode = <span class="text-emerald-400/70">"pool"</span>

[profiles.<span class="text-blue-400/60">"codex-balanced"</span>]
visible_slug = <span class="text-emerald-400/70">"codex-balanced"</span>
